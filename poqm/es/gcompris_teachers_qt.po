msgid "Rules to create a valid dataset:"
msgstr "Reglas para crear un conjunto de datos válido:"

#: server/activities/tens_complement_swap/TensComplementSwapEditor.qml:27
msgctxt "TensComplementSwapEditor|"
msgid "All numbers must be positive integers"
msgstr "Todos los números deben ser enteros positivos"

#: server/activities/tens_complement_swap/TensComplementSwapEditor.qml:29
msgctxt "TensComplementSwapEditor|"
msgid ""
"If \"Random operands\" is not selected, \"Operands\" must contain 1, 2 or 3 "
"entries. Each entry must be a number between 1 and 9. The resulting addition "
"will contain the given entries and their complement to 10."
msgstr ""
"Si no ha seleccionado «Operandos aleatorios», «Operandos» debe contener 1, 2 "
"o 3 entradas. Cada entrada debe ser un número entre 1 y 9. La suma "
"resultante contendrá las entradas indicadas y su complemento a 10."

#: server/activities/tens_complement_swap/TensComplementSwapEditor.qml:31
msgctxt "TensComplementSwapEditor|"
msgid ""
"\"Extra operand\" can contain 1 number between 1 and 9 which will be added "
"to the addition. It is mandatory if \"Operands\" contains 1 number, optional "
"if \"Operands\" contains 2 numbers, and not used if \"Operands\" contains 3 "
"numbers."
msgstr ""
"«Operando adicional» puede contener un número entre 1 y 9, que se añadirá a "
"la suma. Es obligatorio si «Operandos» contiene un número, u opcional si "
"«Operandos» contiene dos números; no se usa si «Operandos» contiene tres "
"números."

