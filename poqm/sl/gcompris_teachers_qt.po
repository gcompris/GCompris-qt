#: server/activities/magic-hat-minus/MagicHatEditor.qml:29
msgctxt "MagicHatEditor|"
msgid "Rules to create a valid dataset:"
msgstr "Pravila za ustvarjanje veljavnega nabora podatkov:"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:31
msgctxt "MagicHatEditor|"
msgid "If \"Use coefficients\" is not checked:"
msgstr "Če možnost \"Uporabi koeficiente\" ni označena:"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:33
#, qt-format
msgctxt "MagicHatEditor|"
msgid ""
"\"Maximum number of stars\" and \"Minimum number of stars\" limit the number "
"of stars for each of the 3 rows of the first operand (the top one). They "
"must contain exactly 3 integer numbers, one for each row. The first entry "
"must be between %1 and %2, the others between 0 and %2. Also the minimum "
"numbers must not be larger than the corresponding maximum numbers."
msgstr ""
"\"Največje število zvezdic\" in \"Najmanjše število zvezdic\" omejujeta "
"število zvezdic za vsako od treh vrstic prvega operanda (zgornjega). "
"Vsebovati morata natanko 3 cela števila, po eno za vsako vrstico. Prvi vnos "
"mora biti med %1 in %2, ostali pa med 0 in %2. Prav tako najmanjša števila "
"ne smejo biti večja od ustreznih največjih števil."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:36
msgctxt "MagicHatEditor|"
msgid ""
"Each row of the second operand (the bottom one) will contain a number of "
"stars generated in such a way that when subtracted from the number of stars "
"of the corresponding row of the first operand, the result will not be more "
"than the \"Maximum result per row\" value."
msgstr ""
"Vsaka vrstica drugega operanda (spodnjega) bo vsebovala število zvezdic "
"ustvarjenih tako, da ko se odšteje od števila zvezdic ustrezne vrstice "
"prvega operanda, rezultat ne bo večji od vrednosti \"Največji rezultat na "
"vrstico\"."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:37
msgctxt "MagicHatEditor|"
msgid ""
"Each row of the second operand (the bottom one) will contain a number of "
"stars generated in such a way that when added to the number of stars of the "
"corresponding row of the first operand, the result will not be more than the "
"\"Maximum result per row\" value."
msgstr ""
"Vsaka vrstica drugega operanda (spodnjega) bo vsebovala število zvezdic, "
"generiranih tako, da ko seštejemo število zvezdic ustrezne vrstice prvega "
"operanda, rezultat ne bo večji od vrednosti \"Največji rezultat na vrstico\"."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:41
msgctxt "MagicHatEditor|"
msgid ""
"If \"Maximum number of stars\" for a row is 0, this row will be empty and "
"hidden for both operands."
msgstr ""
"Če je \"Največje število zvezdic\" za vrstico 0, bo ta vrstica prazna in "
"skrita za oba operanda."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:44
msgctxt "MagicHatEditor|"
msgid ""
"\"Maximum result per row\" must be larger than any value in \"Maximum number "
"of stars\"."
msgstr ""
"\"Največji rezultat na vrstico\" mora biti večji od katere koli vrednosti v "
"\"Največjem številu zvezdic\"."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:46
msgctxt "MagicHatEditor|"
msgid "If \"Use coefficients\" is checked:"
msgstr "Če je označena možnost \"Uporabi koeficiente\":"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:48
msgctxt "MagicHatEditor|"
msgid ""
"\"Row coefficients\" must contain exactly 3 integer numbers. The first entry "
"must be between 1 and 10, the others between 0 and 10, and the sum of the 3 "
"entries must not be larger than 10."
msgstr ""
"\"Koeficienti vrstice\" morajo vsebovati natanko 3 cela števila. Prvi vnos "
"mora biti med 1 in 10, ostali med 0 in 10, vsota treh vnosov pa ne sme biti "
"večja od 10."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:52
msgctxt "MagicHatEditor|"
msgid "Use coefficients"
msgstr "Uporabi koeficiente"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:53
msgctxt "MagicHatEditor|"
msgid "Maximum result per row"
msgstr "Največji rezultat na vrstico"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:54
msgctxt "MagicHatEditor|"
msgid "Use different star sets per row"
msgstr "Uporabite različne množice zvezd na vrstico"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:55
msgctxt "MagicHatEditor|"
msgid "Maximum number of stars"
msgstr "Največje število zvezdic"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:56
msgctxt "MagicHatEditor|"
msgid "Minimum number of stars"
msgstr "Najmanjše število zvezdic"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:57
msgctxt "MagicHatEditor|"
msgid "Coefficient multiplier"
msgstr "Koeficient multiplikatorja"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:58
msgctxt "MagicHatEditor|"
msgid "Row coefficients"
msgstr "Koeficienti vrstice"

#: server/activities/magic-hat-minus/MagicHatEditor.qml:120
msgctxt "MagicHatEditor|"
msgid "Dataset is empty."
msgstr "Množica podatkov je prazna."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:149
#, qt-format
msgctxt "MagicHatEditor|"
msgid ""
"Level %1 must contain exactly 3 integer numbers in \"Maximum number of stars"
"\". The first entry must be between %2 and %3, the others between 0 and %3."
msgstr ""
"Raven %1 mora vsebovati natanko 3 cela števila v \"Največjem številu zvezdic"
"\". Prvi vnos mora biti med %2 in %3, ostali pa med 0 in %3."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:169
#, qt-format
msgctxt "MagicHatEditor|"
msgid ""
"Level %1 must contain exactly 3 integer numbers in \"Minimum number of stars"
"\". The first entry must be between %2 and %3, the others between 0 and %3, "
"and each number must not be larger than the corresponding number in "
"\"Maximum number of stars\"."
msgstr ""
"Raven %1 mora vsebovati natanko 3 cela števila v \"Najmanjšem številu zvezdic"
"\". Prvi vnos mora biti med %2 in %3, ostali med 0 in %3, nobeno število pa "
"ne sme biti večje od ustreznega števila v \"Največjem številu zvezdic\"."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:183
#, qt-format
msgctxt "MagicHatEditor|"
msgid ""
"In Level %1, \"Maximum result per row\" must be larger than any value in "
"\"Maximum number of stars\"."
msgstr ""
"Na ravni %1 mora biti \"Največji rezultat na vrstico\" večji od katere koli "
"vrednosti v \"Največjem številu zvezdic\"."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:213
#, qt-format
msgctxt "MagicHatEditor|"
msgid ""
"Level %1 must contain exactly 3 integer numbers in \"Row coefficients\". The "
"first entry must be between 1 and 10, the others between 0 and 10, and the "
"sum of the 3 entries must not be larger than 10."
msgstr ""
"Raven %1 mora vsebovati natanko 3 cela števila v \"Koeficientih vrstice\". "
"Prvi vnos mora biti med 1 in 10, ostali med 0 in 10, vsota 3 vnosov pa ne "
"sme biti večja od 10."

#: server/activities/magic-hat-minus/MagicHatEditor.qml:219
