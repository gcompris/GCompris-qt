#: server/activities/reversecount/ReversecountEditor.qml:29
msgctxt "ReversecountEditor|"
msgid ""
"The maximum interval is the smaller of 15 and 2 × \"Domino maximum number\"."
msgstr "En büyük aralık, 15’ten küçük ve “En büyük sayı” × 2’dir. "

