#: server/activities/smallnumbers/SmallnumbersEditor.qml:95
#, qt-format
msgctxt "SmallnumbersEditor|"
msgid "\"Numbers\" for level %1 must contain at least two entries."
msgstr "\"Числата\" за ниво %1 трябва да съдържат поне два записа."

#: server/activities/smallnumbers/SmallnumbersEditor.qml:114
#, qt-format
msgctxt "SmallnumbersEditor|"
msgid ""
