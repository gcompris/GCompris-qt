msgid "\"Numbers\" for level %1 must not be empty."
msgstr "Поле «Числа» для рівня %1 має бути непорожнім."

#: server/activities/smallnumbers/SmallnumbersEditor.qml:95
#, qt-format
msgctxt "SmallnumbersEditor|"
msgid "\"Numbers\" for level %1 must contain at least two entries."
msgstr "У полі «Числа» рівня %1 мають міститися принаймні два записи."

