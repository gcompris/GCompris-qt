msgstr "મહત્તમ કિંમત"

#: server/activities/learn_subtractions/ActivityEditor.qml:16
msgctxt "ActivityEditor|"
msgid ""
"\"Subtractions\" must contain a list of subtractions which results are "
"between 0 and 9."
msgstr ""
"\"બાદબાકી\" માં બાદબાકીની યાદી હોવી આવશ્યક છે જેનું પરિણામ 0 અને 9 ની વચ્ચે હોય."

