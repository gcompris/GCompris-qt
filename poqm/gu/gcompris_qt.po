#: activities/land_safe/resource/2/Data.qml:38
msgctxt "Data|"
msgid "Titan"
msgstr "ટાઇટન"

#: activities/land_safe/resource/1/Data.qml:48
#: activities/land_safe/resource/2/Data.qml:47
msgctxt "Data|"
msgid "Moon"
msgstr "ચંદ્ર"

#: activities/land_safe/resource/1/Data.qml:57
#: activities/land_safe/resource/2/Data.qml:56
msgctxt "Data|"
msgid "Mars"
msgstr "મંગળ"

#: activities/land_safe/resource/1/Data.qml:66
#: activities/land_safe/resource/2/Data.qml:65
msgctxt "Data|"
