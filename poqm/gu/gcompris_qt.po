#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:22
#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:23
#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:24
#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:27
#, qt-format
msgctxt "Data|"
msgid "%1 lb"
msgstr "%1 પાઉન્ડ"

#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:30
#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:35
msgctxt "Data|"
msgid ""
"The \"lb\" symbol at the end of a number means pound. The pound is a unit of "
"mass, a property which corresponds to the common perception of how \"heavy\" "
"an object is. This unit is used in the USA."
msgstr ""
"સંખ્યાની અંતે \"lb\" ચિહ્નનો અર્થ પાઉન્ડ થાય છે. પાઉન્ડ એ દળનો એકમ છે, જે વસ્તુ કેટલી \"ભારે"
"\" છે તેની સામાન્ય ધારણાને અનુરૂપ છે. આ એકમનો ઉપયોગ યુએસએ (USA) માં થાય છે."

#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:84
#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:91
#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:98
#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:105
#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:65
#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:79
#, qt-format
msgctxt "Data|"
msgid "Enter the weight of the gift in pound: %1"
msgstr "ભેટનું વજન પાઉન્ડમાં દાખલ કરો: %1"

#: activities/scalesboard_weight_avoirdupois/resource/5/Data.qml:13
msgctxt "Data|"
msgid "Balance up to 100 ounces."
msgstr "100 ઔંસ સુધી સંતુલિત કરો."

#: activities/scalesboard_weight_avoirdupois/resource/5/Data.qml:26
msgctxt "Data|"
msgid ""
"The \"oz\" symbol at the end of a number means ounce. \n"
" Drop weights on the left side to balance the scales."
msgstr ""
"સંખ્યાની અંતે \"oz\" ચિહ્નનો અર્થ ઔંસ થાય છે. \n"
" ત્રાજવાને સંતુલિત કરવા માટે ડાબી બાજુએ વજન મૂકો."

#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:13
msgctxt "Data|"
msgid "Balance up to 10 pounds including ounces."
msgstr "ઔંસ સાથે 10 પાઉન્ડ સુધી સંતુલિત કરો."

#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:52
#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:58
msgctxt "Data|"
msgid ""
"Remember, one pound (\"lb\") equals sixteen ounces (\"oz\"). \n"
" Drop the weights on the left side of the scales to balance it."
msgstr ""
"યાદ રાખો, એક પાઉન્ડ (\"lb\") એટલે સોળ ઔંસ (\"oz\"). \n"
" ત્રાજવાને સંતુલિત કરવા માટે ડાબી બાજુએ વજન મૂકો."

#: activities/share/ActivityConfig.qml:27
msgctxt "ActivityConfig|"
msgid "Display counters"
msgstr "કાઉન્ટર્સ દર્શાવો"

#. Activity title
#: activities/share/ActivityInfo.qml:15
msgctxt "ActivityInfo|"
msgid "Share pieces of candy"
msgstr "કેન્ડીના ટુકડા વહેંચો"

#. Help title
#: activities/share/ActivityInfo.qml:17
msgctxt "ActivityInfo|"
msgid "Try to split the pieces of candy between a given number of children."
msgstr "બાળકોની આપેલી સંખ્યા વચ્ચે કેન્ડીના ટુકડા વહેંચવાનો પ્રયાસ કરો."

#. Help goal
#: activities/share/ActivityInfo.qml:20
msgctxt "ActivityInfo|"
msgid "Learn to share, practice division."
msgstr "વહેંચતા શીખો, ભાગાકારનો અભ્યાસ કરો."

#. Help prerequisite
#: activities/share/ActivityInfo.qml:22
msgctxt "ActivityInfo|"
msgid "Know how to count."
msgstr "ગણતરી કરતા શીખો."

#. Help manual
#: activities/share/ActivityInfo.qml:24
msgctxt "ActivityInfo|"
msgid ""
"Follow the instructions shown on the screen: first, drag the given number of "
"boys/girls to the center, then drag pieces of candy to each child's "
"rectangle."
msgstr ""
"સ્ક્રીન પર આપેલી સૂચનાઓનું પાલન કરો: પહેલા, છોકરાઓ/છોકરીઓની આપેલી સંખ્યાને મધ્યમાં ખેંચો, "
"પછી દરેક બાળકના લંબચોરસમાં કેન્ડીના ટુકડા મૂકો."

#: activities/share/ActivityInfo.qml:25
msgctxt "ActivityInfo|"
msgid "If there is a rest, it needs to be placed inside the candy jar."
msgstr "જો કંઈ બાકી રહે, તો તેને કેન્ડી જારમાં મૂકવાની જરૂર છે."

#: activities/share/resource/1/Data.qml:15
msgctxt "Data|"
msgid "Maximum 25 pieces of candy and 5 kids, no rest."
msgstr "મહત્તમ 25 કેન્ડી અને 5 બાળકો, કોઈ બાકી નહીં."

#: activities/share/resource/1/Data.qml:22
#: activities/share/resource/2/Data.qml:22
msgctxt "Data|"
msgid ""
"Paul wants to share 2 pieces of candy equally between 2 of his girl friends. "
"Can you help him? First, place the children in the center, then drag the "
"pieces of candy to each of them."
msgstr ""
"પોલ તેની 2 છોકરી મિત્રો વચ્ચે 2 કેન્ડી સમાન રીતે વહેંચવા માંગે છે. શું તમે તેને મદદ કરી શકો? "
"પહેલા બાળકોને મધ્યમાં મૂકો, પછી દરેકને કેન્ડીના ટુકડા આપો."

#: activities/share/resource/1/Data.qml:32
msgctxt "Data|"
msgid "Now he wants to share 4 pieces of candy equally among his friends."
msgstr "હવે તે તેના મિત્રો વચ્ચે 4 કેન્ડી સમાન રીતે વહેંચવા માંગે છે."

#: activities/share/resource/1/Data.qml:42
msgctxt "Data|"
msgid ""
"Can you now share 6 of Paul's pieces of candy equally among his friends?"
msgstr "શું તમે હવે પોલની 6 કેન્ડી તેના મિત્રો વચ્ચે સમાન રીતે વહેંચી શકો છો?"

#: activities/share/resource/1/Data.qml:52
msgctxt "Data|"
msgid ""
"Some of his friends already have pieces of candy. He wants to give them 7 "
"more pieces so that they all have the same amount."
msgstr ""
"તેના કેટલાક મિત્રો પાસે પહેલેથી જ કેન્ડી છે. તે તેમને વધુ 7 કેન્ડી આપવા માંગે છે જેથી દરેક પાસે "
"સમાન સંખ્યા હોય."

#: activities/share/resource/1/Data.qml:62
msgctxt "Data|"
msgid ""
"Paul has only 12 pieces of candy left. He eats 2 pieces of candy and he "
"gives the rest to his friends. Can you help him split equally the 10 "
"remaining pieces of candy?"
msgstr ""
"પોલ પાસે માત્ર 12 કેન્ડી બાકી છે. તે 2 કેન્ડી ખાઈ જાય છે અને બાકીની તેના મિત્રોને આપે છે. શું "
"તમે તેને બાકી રહેલી 10 કેન્ડી સમાન રીતે વહેંચવામાં મદદ કરી શકો?"

#: activities/share/resource/1/Data.qml:77
msgctxt "Data|"
msgid ""
"George wants to share 3 pieces of candy equally between 3 of his girl "
"friends. Can he split the pieces of candy equally?"
msgstr ""
"જ્યોર્જ તેની 3 છોકરી મિત્રો વચ્ચે 3 કેન્ડી સમાન રીતે વહેંચવા માંગે છે. શું તે કેન્ડી સમાન રીતે "
"વહેંચી શકશે?"

#: activities/share/resource/1/Data.qml:87
msgctxt "Data|"
msgid ""
"Maria wants to share 6 pieces of candy equally between 3 of her friends: 1 "
"girl and 2 boys. Can she split the pieces of candy equally?"
msgstr ""
"મારિયા તેના 3 મિત્રો વચ્ચે 6 કેન્ડી સમાન રીતે વહેંચવા માંગે છે: 1 છોકરી અને 2 છોકરાઓ. શું તે "
"કેન્ડી સમાન રીતે વહેંચી શકશે?"

#: activities/share/resource/1/Data.qml:97
msgctxt "Data|"
msgid ""
"John wants to share 8 pieces of candy equally between 3 of his friends: 1 "
"boy and 2 girls. The boy already has one. Can he make sure that they all "
"have the same amount?"
msgstr ""
"જોન તેના 3 મિત્રો વચ્ચે 8 કેન્ડી સમાન રીતે વહેંચવા માંગે છે: 1 છોકરો અને 2 છોકરીઓ. છોકરા "
"પાસે એક કેન્ડી પહેલેથી જ છે. શું તે ખાતરી કરી શકે કે બધા પાસે સમાન જથ્થો હોય?"

#: activities/share/resource/1/Data.qml:107
msgctxt "Data|"
msgid ""
"Paul wants to share 12 pieces of candy equally between 3 of his friends: 2 "
"boys and 1 girl. Can he split the pieces of candy equally?"
msgstr ""
"પોલ તેના 3 મિત્રો વચ્ચે 12 કેન્ડી સમાન રીતે વહેંચવા માંગે છે: 2 છોકરાઓ અને 1 છોકરી. શું તે "
"કેન્ડી સમાન રીતે વહેંચી શકશે?"

#: activities/share/resource/1/Data.qml:117
msgctxt "Data|"
msgid ""
"Maria wants to share 11 pieces of candy between 3 of her friends: 1 boy and "
"2 girls. The girls already have some pieces of candy. Can she split the "
"pieces of candy so that they all have the same amount?"
msgstr ""
"મારિયા તેના 3 મિત્રો વચ્ચે 11 કેન્ડી વહેંચવા માંગે છે: 1 છોકરો અને 2 છોકરીઓ. છોકરીઓ પાસે "
"પહેલેથી જ કેટલીક કેન્ડી છે. શું તે કેન્ડી એવી રીતે વહેંચી શકે કે બધા પાસે સમાન જથ્થો હોય?"

#: activities/share/resource/1/Data.qml:132
#: activities/share/resource/2/Data.qml:122
msgctxt "Data|"
msgid ""
"Alice wants to share 4 pieces of candy equally between 4 of her girl "
"friends. Can you help her?"
msgstr ""
"એલિસ તેની 4 છોકરી મિત્રો વચ્ચે 4 કેન્ડી સમાન રીતે વહેંચવા માંગે છે. શું તમે તેને મદદ કરી શકો?"

#: activities/share/resource/1/Data.qml:142
msgctxt "Data|"
msgid "Now, Alice wants to give 8 pieces of candy to her friends."
msgstr "હવે, એલિસ તેના મિત્રોને 8 કેન્ડી આપવા માંગે છે."

#: activities/share/resource/1/Data.qml:152
msgctxt "Data|"
msgid ""
"Alice wants to give 10 pieces of candy to her friends, 1 girl and 3 boys, so "
"that they all have the same amount. The girls already have some pieces of "
"candy."
msgstr ""
"એલિસ તેના મિત્રોને (1 છોકરી અને 3 છોકરાઓ) 10 કેન્ડી આપવા માંગે છે, જેથી બધા પાસે સમાન "
"જથ્થો હોય. છોકરી પાસે પહેલેથી જ થોડી કેન્ડી છે."

#: activities/share/resource/1/Data.qml:162
msgctxt "Data|"
msgid "Alice wants to give 16 pieces of candy to her friends."
msgstr "એલિસ તેના મિત્રોને 16 કેન્ડી આપવા માંગે છે."

#: activities/share/resource/1/Data.qml:172
msgctxt "Data|"
msgid ""
"Alice wants to give pieces of candy to 4 friends. Some of them already have "
"some pieces of candy. Can you help her split 14 pieces of candy so that all "
"her friends have the same amount?"
msgstr ""
"એલિસ 4 મિત્રોને કેન્ડી આપવા માંગે છે. તેમાંથી કેટલાક પાસે પહેલેથી જ કેન્ડી છે. શું તમે તેને 14 "
"કેન્ડી વહેંચવામાં મદદ કરી શકો જેથી બધા મિત્રો પાસે સમાન જથ્થો હોય?"

#: activities/share/resource/1/Data.qml:187
msgctxt "Data|"
msgid ""
"Michael wants to share 5 pieces of candy equally between 5 of his girl "
"friends. Can you help him?"
msgstr ""
"માઈકલ તેની 5 છોકરી મિત્રો વચ્ચે 5 કેન્ડી સમાન રીતે વહેંચવા માંગે છે. શું તમે તેને મદદ કરી શકો?"

#: activities/share/resource/1/Data.qml:197
msgctxt "Data|"
msgid ""
"Helen has 5 friends: 2 boys and 3 girls. She wants to give them 10 pieces of "
"candy. Help her split the pieces of candy equally between her friends."
msgstr ""
"હેલન પાસે 5 મિત્રો છે: 2 છોકરાઓ અને 3 છોકરીઓ. તે તેમને 10 કેન્ડી આપવા માંગે છે. તેના મિત્રો "
"વચ્ચે કેન્ડી સમાન રીતે વહેંચવામાં તેને મદદ કરો."

#: activities/share/resource/1/Data.qml:207
msgctxt "Data|"
msgid ""
"Michelle wants to share 12 pieces of candy equally between her 4 brothers "
"and 1 sister, so that they all have the same amount. Her sister already has "
"some pieces of candy."
msgstr ""
"મિશેલ તેના 4 ભાઈઓ અને 1 બહેન વચ્ચે 12 કેન્ડી સમાન રીતે વહેંચવા માંગે છે, જેથી બધા પાસે સમાન "
"જથ્થો હોય. તેની બહેન પાસે પહેલેથી જ થોડી કેન્ડી છે."

#: activities/share/resource/1/Data.qml:217
msgctxt "Data|"
msgid ""
"Thomas wants to share his 20 pieces of candy with his friends: 1 boy and 4 "
"girls. Can you help him?"
msgstr ""
"થોમસ તેના 20 કેન્ડીના ટુકડા તેના મિત્રો સાથે વહેંચવા માંગે છે: 1 છોકરો અને 4 છોકરીઓ. શું તમે "
"તેને મદદ કરી શકો?"

#: activities/share/resource/1/Data.qml:227
msgctxt "Data|"
msgid ""
"Paul wants to share 20 pieces of candy equally between 5 of his friends. "
"They already have one piece of candy each. Can you help him?"
msgstr ""
"પોલ તેના 5 મિત્રો વચ્ચે 20 કેન્ડી સમાન રીતે વહેંચવા માંગે છે. તેમની પાસે પહેલેથી જ એક-એક "
"કેન્ડી છે. શું તમે તેને મદદ કરી શકો?"

#: activities/share/resource/1/Data.qml:242
msgctxt "Data|"
msgid ""
"Charles wants to share his 6 pieces of candy equally with 2 of his girl "
"friends. Can he split the pieces of candy equally?"
msgstr ""
"ચાર્લ્સ તેની 6 કેન્ડી તેના 2 છોકરી મિત્રો સાથે સમાન રીતે વહેંચવા માંગે છે. શું તે કેન્ડી સમાન "
"રીતે વહેંચી શકશે?"

#: activities/share/resource/1/Data.qml:252
msgctxt "Data|"
msgid ""
"For her birthday, Elizabeth has 8 pieces of candy to share with 3 of her "
"friends: 2 girls and 1 boy. The girls already have some pieces of candy. How "
"should she split the pieces of candy so that they all have the same amount?"
msgstr ""
"તેના જન્મદિવસ પર, એલિઝાબેથ પાસે તેના 3 મિત્રો સાથે વહેંચવા માટે 8 કેન્ડી છે: 2 છોકરીઓ અને "
"1 છોકરો. છોકરીઓ પાસે પહેલેથી જ થોડી કેન્ડી છે. તેણે કેન્ડી કેવી રીતે વહેંચવી જોઈએ જેથી બધા "
"પાસે સમાન જથ્થો હોય?"

#: activities/share/resource/1/Data.qml:262
msgctxt "Data|"
msgid ""
"Jason's father gave him 16 pieces of candy to share equally with his "
"friends: 2 boys and 2 girls. Help him give the pieces of candy to his "
"friends."
msgstr ""
"જેસનના પિતાએ તેને તેના મિત્રો સાથે સમાન રીતે વહેંચવા માટે 16 કેન્ડી આપી: 2 છોકરાઓ અને 2 "
"છોકરીઓ. તેના મિત્રોને કેન્ડી આપવામાં તેને મદદ કરો."

#: activities/share/resource/1/Data.qml:272
msgctxt "Data|"
msgid ""
"George wants to share 14 pieces of candy between 4 of his friends: 2 girls "
"and 2 boys. The boys already have one piece of candy each. He wants all of "
"them to have the same amount."
msgstr ""
"જ્યોર્જ તેના 4 મિત્રો વચ્ચે 14 કેન્ડી વહેંચવા માંગે છે: 2 છોકરીઓ અને 2 છોકરાઓ. છોકરાઓ પાસે "
"પહેલેથી જ એક-એક કેન્ડી છે. તે ઈચ્છે છે કે બધા પાસે સમાન જથ્થો હોય."

#: activities/share/resource/1/Data.qml:282
msgctxt "Data|"
msgid ""
"Maria wants to share 25 pieces of candy equally between 5 of her friends: 3 "
"girls and 2 boys. Can she split the pieces of candy equally?"
msgstr ""
"મારિયા તેના 5 મિત્રો વચ્ચે 25 કેન્ડી સમાન રીતે વહેંચવા માંગે છે: 3 છોકરીઓ અને 2 છોકરાઓ. શું "
"તે કેન્ડી સમાન રીતે વહેંચી શકશે?"

#: activities/share/resource/2/Data.qml:15
msgctxt "Data|"
msgid "Maximum 25 pieces of candy and 5 kids, possible rest."
msgstr "મહત્તમ 25 કેન્ડી અને 5 બાળકો, શક્ય છે કે કંઈક બાકી રહે."

#: activities/share/resource/2/Data.qml:32
msgctxt "Data|"
msgid "Now he wants to share 5 pieces of candy among his friends."
msgstr "હવે તે તેના મિત્રો વચ્ચે 5 કેન્ડી વહેંચવા માંગે છે."

#: activities/share/resource/2/Data.qml:42
msgctxt "Data|"
msgid "Can you now share 7 of Paul's pieces of candy among his friends?"
msgstr "શું તમે હવે પોલની 7 કેન્ડી તેના મિત્રો વચ્ચે વહેંચી શકો છો?"

#: activities/share/resource/2/Data.qml:52
msgctxt "Data|"
msgid "Can you now share 8 of Paul's pieces of candy among his friends?"
msgstr "શું તમે હવે પોલની 8 કેન્ડી તેના મિત્રો વચ્ચે વહેંચી શકો છો?"

#: activities/share/resource/2/Data.qml:62
msgctxt "Data|"
msgid ""
"Paul has only 11 pieces of candy left. He eats 2 pieces of candy and he "
"gives the rest to his friends. Can you help him split equally the 9 "
"remaining pieces of candy?"
msgstr ""
"પોલ પાસે માત્ર 11 કેન્ડી બાકી છે. તે 2 કેન્ડી ખાઈ જાય છે અને બાકીની તેના મિત્રોને આપે છે. શું "
"તમે તેને બાકી રહેલી 9 કેન્ડી સમાન રીતે વહેંચવામાં મદદ કરી શકો?"

#: activities/share/resource/2/Data.qml:77
msgctxt "Data|"
msgid ""
"Bob wants to share 3 pieces of candy equally between 3 of his girl friends. "
"Can he split the pieces of candy equally?"
msgstr ""
"બોબ તેની 3 છોકરી મિત્રો વચ્ચે 3 કેન્ડી સમાન રીતે વહેંચવા માંગે છે. શું તે કેન્ડી સમાન રીતે "
"વહેંચી શકશે?"

#: activities/share/resource/2/Data.qml:87
msgctxt "Data|"
msgid ""
"Harry wants to share 8 pieces of candy between 3 of his friends: 1 boy and 2 "
"girls. The boy already has one piece of candy. Can he split the pieces of "
"candy so that they all have the same amount?"
msgstr ""
"હેરી તેના 3 મિત્રો વચ્ચે 8 કેન્ડી વહેંચવા માંગે છે: 1 છોકરો અને 2 છોકરીઓ. છોકરા પાસે પહેલેથી "
"જ એક કેન્ડી છે. શું તે કેન્ડી એવી રીતે વહેંચી શકે કે બધા પાસે સમાન જથ્થો હોય?"

#: activities/share/resource/2/Data.qml:97
msgctxt "Data|"
msgid ""
"Maria wants to share 8 pieces of candy between 3 of her friends: 1 boy and 2 "
"girls. The girls already have some pieces of candy. Can she split the pieces "
"of candy so that they all have the same amount?"
msgstr ""
"મારિયા તેના 3 મિત્રો વચ્ચે 8 કેન્ડી વહેંચવા માંગે છે: 1 છોકરો અને 2 છોકરીઓ. છોકરીઓ પાસે "
"પહેલેથી જ થોડી કેન્ડી છે. શું તે કેન્ડી એવી રીતે વહેંચી શકે કે બધા પાસે સમાન જથ્થો હોય?"

#: activities/share/resource/2/Data.qml:107
msgctxt "Data|"
msgid ""
"Harry wants to share 12 pieces of candy between 3 of his friends: 1 boy and "
"2 girls. The boy already has some pieces of candy. Can he split the pieces "
"of candy so that they all have the same amount?"
msgstr ""
"હેરી તેના 3 મિત્રો વચ્ચે 12 કેન્ડી વહેંચવા માંગે છે: 1 છોકરો અને 2 છોકરીઓ. છોકરા પાસે "
"પહેલેથી જ થોડી કેન્ડી છે. શું તે કેન્ડી એવી રીતે વહેંચી શકે કે બધા પાસે સમાન જથ્થો હોય?"

#: activities/share/resource/2/Data.qml:132
msgctxt "Data|"
msgid "Now, Alice wants to share 8 pieces of candy equally among her friends."
msgstr "હવે, એલિસ તેના મિત્રો વચ્ચે 8 કેન્ડી સમાન રીતે વહેંચવા માંગે છે."

#: activities/share/resource/2/Data.qml:142
msgctxt "Data|"
msgid ""
"Can you help Alice share 10 pieces of candy equally among her friends: 1 "
"girl and 3 boys? The girl already has some pieces of candy."
msgstr ""
"શું તમે એલિસને તેના મિત્રો (1 છોકરી અને 3 છોકરાઓ) વચ્ચે 10 કેન્ડી સમાન રીતે વહેંચવામાં મદદ "
"કરી શકો? છોકરી પાસે પહેલેથી જ થોડી કેન્ડી છે."

#: activities/share/resource/2/Data.qml:152
msgctxt "Data|"
msgid "Alice wants to share 16 pieces of candy equally among her friends."
msgstr "એલિસ તેના મિત્રો વચ્ચે 16 કેન્ડી સમાન રીતે વહેંચવા માંગે છે."

#: activities/share/resource/2/Data.qml:162
msgctxt "Data|"
msgid ""
"Alice has 14 pieces of candy left. She wants to share them equally among her "
"friends. The boys already have some pieces of candy. Can you help her split "
"the pieces of candy equally?"
msgstr ""
"એલિસ પાસે 14 કેન્ડી બાકી છે. તે તેમને તેના મિત્રો વચ્ચે સમાન રીતે વહેંચવા માંગે છે. છોકરાઓ "
"પાસે પહેલેથી જ થોડી કેન્ડી છે. શું તમે તેને કેન્ડી સમાન રીતે વહેંચવામાં મદદ કરી શકો?"

#: activities/share/resource/2/Data.qml:177
msgctxt "Data|"
msgid ""
"Help Jon share 11 pieces of candies equally between five girls. The rest "
"will remain to Jon."
msgstr ""
"જોનને 11 કેન્ડી પાંચ છોકરીઓમાં સરખે ભાગે વહેંચવામાં મદદ કરો. બાકી રહેલી કેન્ડી જોન પાસે "
"રહેશે."

#: activities/share/resource/2/Data.qml:187
msgctxt "Data|"
msgid ""
"Jon wants to share the rest of his pieces of candies with his brothers and "
"his sisters. Can you split them equally, knowing that his brothers already "
"have 2 pieces of candy?"
msgstr ""
"જોન તેની બાકીની કેન્ડી તેના ભાઈઓ અને બહેનો સાથે વહેંચવા માંગે છે. શું તમે તેને સરખે ભાગે વહેંચી "
"શકો છો, એ જાણીને કે તેના ભાઈઓ પાસે પહેલેથી જ 2 કેન્ડી છે?"

#: activities/share/resource/2/Data.qml:197
msgctxt "Data|"
msgid ""
"Help Tux split 19 pieces of candies between his friends: 4 boys and 1 girl."
msgstr "ટક્સને તેની 19 કેન્ડી તેના મિત્રો: 4 છોકરાઓ અને 1 છોકરી વચ્ચે વહેંચવામાં મદદ કરો."

#: activities/share/resource/2/Data.qml:207
msgctxt "Data|"
msgid "Help Maria share 18 pieces of candy equally between 3 boys and 2 girls."
msgstr "મારિયાને 18 કેન્ડી 3 છોકરાઓ અને 2 છોકરીઓ વચ્ચે સરખે ભાગે વહેંચવામાં મદદ કરો."

#: activities/share/resource/2/Data.qml:222
msgctxt "Data|"
msgid ""
"Charles wants to share his 6 pieces of candy equally between 2 of his girl "
"friends. Can he split the pieces of candy equally?"
msgstr ""
"ચાર્લ્સ તેની 6 કેન્ડી તેની 2 છોકરી મિત્રો વચ્ચે સરખે ભાગે વહેંચવા માંગે છે. શું તે કેન્ડીને સરખે "
"ભાગે વહેંચી શકે છે?"

#: activities/share/resource/2/Data.qml:232
msgctxt "Data|"
msgid ""
"For her birthday, Elizabeth has 8 pieces of candy to share with 3 of her "
"friends equally: 2 girls and 1 boy. How should she split the pieces of candy "
"between her friends?"
msgstr ""
"તેના જન્મદિવસ પર, એલિઝાબેથ પાસે તેના 3 મિત્રો: 2 છોકરીઓ અને 1 છોકરા વચ્ચે સરખે ભાગે "
"વહેંચવા માટે 8 કેન્ડી છે. તેણે તેના મિત્રો વચ્ચે કેન્ડી કેવી રીતે વહેંચવી જોઈએ?"

#: activities/share/resource/2/Data.qml:242
msgctxt "Data|"
msgid ""
"Jason's father gave him 17 pieces of candy to share equally between his "
"friends: 2 boys and 2 girls. Help him give the pieces of candy to his "
"friends."
msgstr ""
"જેસનના પિતાએ તેને તેના મિત્રો: 2 છોકરાઓ અને 2 છોકરીઓ વચ્ચે સરખે ભાગે વહેંચવા માટે 17 કેન્ડી "
"આપી. તેને તેના મિત્રોને કેન્ડી આપવામાં મદદ કરો."

#: activities/share/resource/2/Data.qml:252
msgctxt "Data|"
msgid ""
"George wants to share 14 pieces of candy equally between 4 of his friends: 2 "
"girls and 2 boys. Can he equally split the pieces of candy between his "
"friends?"
msgstr ""
"જ્યોર્જ તેની 14 કેન્ડી તેના 4 મિત્રો: 2 છોકરીઓ અને 2 છોકરાઓ વચ્ચે સરખે ભાગે વહેંચવા માંગે છે. "
"શું તે તેના મિત્રો વચ્ચે કેન્ડીને સરખે ભાગે વહેંચી શકે છે?"

#: activities/share/resource/2/Data.qml:262
msgctxt "Data|"
msgid ""
"Maria wants to share 23 pieces of candy equally between 5 of her friends: 3 "
"girls and 2 boys. Can she share the pieces of candy equally between her "
"friends?"
msgstr ""
"મારિયા તેની 23 કેન્ડી તેના 5 મિત્રો: 3 છોકરીઓ અને 2 છોકરાઓ વચ્ચે સરખે ભાગે વહેંચવા માંગે "
"છે. શું તે તેના મિત્રો વચ્ચે કેન્ડીને સરખે ભાગે વહેંચી શકે છે?"

#: activities/share/resource/3/Data.qml:15
msgctxt "Data|"
msgid "Maximum 30 pieces of candy and 6 kids, possible rest."
msgstr "મહત્તમ 30 કેન્ડી અને 6 બાળકો, બાકી રહેવાની શક્યતા."

#: activities/share/share.js:150
#, qt-format
msgctxt ""
"share|First part of Place %n boy(s) and %n girl(s) in the center. Then split "
"%n pieces of candy equally between them."
msgid "Place %n boy(s) "
msgid_plural "Place %n boy(s) "
msgstr[0] "વચ્ચે %n છોકરો(ઓ) અને %n છોકરી(ઓ) મૂકો."
msgstr[1] "વચ્ચે %n છોકરાઓ મૂકો"

#: activities/share/share.js:154
#, qt-format
msgctxt ""
"share|Second part of Place %n boy(s) and %n girl(s) in the center. Then "
"split %n pieces of candy equally between them."
msgid "and %n girl(s) in the center. "
msgid_plural "and %n girl(s) in the center. "
msgstr[0] "અને વચ્ચે %n છોકરી મૂકો."
msgstr[1] "અને વચ્ચે %n છોકરી મૂકો."

#: activities/share/share.js:158
#, qt-format
msgctxt ""
"share|Third part of Place %n boy(s) and %n girl(s) in the center. Then split "
"%n pieces of candy equally between them."
msgid "Then split %n pieces of candy equally between them."
msgid_plural "Then split %n pieces of candy equally between them."
msgstr[0] "પછી તેમની વચ્ચે ચોકલેટના %n ટુકડા સમાન રીતે વહેંચો."
msgstr[1] "પછી તેમની વચ્ચે ચોકલેટના %n ટુકડા સમાન રીતે વહેંચો."

#: activities/share/Share.qml:422
#, qt-format
