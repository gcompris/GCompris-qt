msgid "Space, Return or Enter: select or deselect current value or operator"
msgstr "સ્પેસ, રિટર્ન અથવા એન્ટર: વર્તમાન કિંમત અથવા ચિહ્ન પસંદ કરવા કે કાઢી નાખવા માટે"

#: activities/guess24/ActivityInfo.qml:27
msgctxt "ActivityInfo|"
msgid "Operator keys (+, -, *, /): select operator"
msgstr "ચિહ્નોની કી (+, -, *, /): ચિહ્ન પસંદ કરવા માટે"

#: activities/guess24/ActivityInfo.qml:28
msgctxt "ActivityInfo|"
msgid "Backspace or Delete: cancel last operation"
msgstr "બેકસ્પેસ અથવા ડિલીટ: છેલ્લી પ્રક્રિયા રદ કરવા માટે"

#: activities/guess24/ActivityInfo.qml:29
msgctxt "ActivityInfo|"
msgid "Tabulation: switch between numbers and operators"
msgstr "ટેબ કી: સંખ્યાઓ અને ચિહ્નો વચ્ચે સ્વિચ કરવા માટે"

#: activities/guess24/Guess24.qml:142
msgctxt "Guess24|"
msgid "Use the four numbers with given operators to find 24."
msgstr "24 મેળવવા માટે આપેલી ચાર સંખ્યાઓ અને ચિહ્નોનો ઉપયોગ કરો."

#: activities/guess24/resource/1/Data.qml:13
msgctxt "Data|"
