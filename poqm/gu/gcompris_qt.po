#| msgid "Maximum value: 50000."
msgctxt "Data|"
msgid "Maximum value: 5000."
msgstr "મહત્તમ મૂલ્ય: 50000."

#: activities/target/resource/5/Data.qml:14
msgctxt "Data|"
msgid "Maximum value: 50000."
msgstr "મહત્તમ મૂલ્ય: 50000."

#. Activity title
#: activities/tens_complement_calculate/ActivityInfo.qml:14
msgctxt "ActivityInfo|"
msgid "Calculate with ten's complement"
msgstr "દસના પૂરક સાથે ગણતરી કરો"

#. Help title
#: activities/tens_complement_calculate/ActivityInfo.qml:16
msgctxt "ActivityInfo|"
msgid ""
"Swap the numbers to create pairs equal to ten and input the answer of the "
"final sum."
msgstr ""
"દસ બરાબર જોડી બનાવવા માટે સંખ્યાઓની અદલાબદલી કરો અને અંતિમ સરવાળાનો જવાબ દાખલ કરો."

#. Help goal
#: activities/tens_complement_calculate/ActivityInfo.qml:19
msgctxt "ActivityInfo|"
msgid ""
"Learn to use ten's complement to optimize the order of numbers in an "
"operation and calculate the result."
msgstr ""
"ઓપરેશનમાં સંખ્યાઓના ક્રમને શ્રેષ્ઠ બનાવવા અને પરિણામની ગણતરી કરવા માટે દસના પૂરકનો ઉપયોગ "
"કરવાનું શીખો."

#. Help prerequisite
#: activities/tens_complement_calculate/ActivityInfo.qml:21
msgctxt "ActivityInfo|"
msgid "Numbers from 1 to 30 and additions."
msgstr "1 થી 30 સુધીની સંખ્યાઓ અને સરવાળા."

#. Help manual
#: activities/tens_complement_calculate/ActivityInfo.qml:23
msgctxt "ActivityInfo|"
msgid ""
"Create pairs of numbers equal to ten within each parentheses. Select a "
"number, then select another number of the same operation to swap their "
"position. On each line, input the final sum in last box. When all the lines "
"are completed, press the OK button to validate the answers. If some answers "
"are incorrect, a cross icon will appear on the corresponding lines. Correct "
"the errors, then press the OK button again."
msgstr ""
"દરેક કૌંસમાં દસ બરાબર સંખ્યાઓની જોડી બનાવો. એક સંખ્યા પસંદ કરો, પછી તેમની સ્થિતિ બદલવા "
"માટે સમાન ઓપરેશનની બીજી સંખ્યા પસંદ કરો. દરેક લીટી પર, છેલ્લા બોક્સમાં અંતિમ સરવાળો "
"દાખલ કરો. જ્યારે બધી લીટીઓ પૂર્ણ થઈ જાય, ત્યારે જવાબો માન્ય કરવા માટે OK બટન દબાવો. "
"જો કેટલાક જવાબો ખોટા હોય, તો સંબંધિત લીટીઓ પર ક્રોસ આઇકોન દેખાશે. ભૂલો સુધારો, પછી "
"ફરીથી OK બટન દબાવો."

#: activities/tens_complement_calculate/resource/1/Data.qml:52
msgctxt "Data|"
msgid "1 pair to make from 3 numbers."
msgstr "3 સંખ્યાઓમાંથી 1 જોડી બનાવો."

#: activities/tens_complement_calculate/resource/2/Data.qml:9
#: activities/tens_complement_swap/resource/2/Data.qml:9
msgctxt "Data|"
msgid "2 pairs to make from 5 numbers."
msgstr "5 સંખ્યાઓમાંથી 2 જોડી બનાવો."

#. Activity title
#: activities/tens_complement_find/ActivityInfo.qml:14
msgctxt "ActivityInfo|"
msgid "Find ten's complement"
msgstr "દસનું પૂરક શોધો"

#. Help title
#: activities/tens_complement_find/ActivityInfo.qml:16
msgctxt "ActivityInfo|"
msgid "Find the ten's complement of each number."
msgstr "દરેક સંખ્યાનું દસનું પૂરક શોધો."

#. Help goal
#: activities/tens_complement_find/ActivityInfo.qml:19
msgctxt "ActivityInfo|"
msgid "Learn to find ten's complement."
msgstr "દસનું પૂરક શોધવાનું શીખો."

#. Help prerequisite
#: activities/tens_complement_find/ActivityInfo.qml:21
msgctxt "ActivityInfo|"
msgid "Numbers from 1 to 10 and addition."
msgstr "1 થી 10 સુધીની સંખ્યાઓ અને સરવાળો."

#: activities/tens_complement_find/ActivityInfo.qml:23
#: activities/tens_complement_use/ActivityInfo.qml:24
msgctxt "ActivityInfo|"
msgid ""
"When all the lines are completed, press the OK button to validate the "
"answers. If some answers are incorrect, a cross icon will appear on the "
"corresponding lines. To correct the errors, click on the wrong numbers to "
"remove them and repeat the previous steps."
msgstr ""
"જ્યારે બધી લીટીઓ પૂર્ણ થઈ જાય, ત્યારે જવાબો માન્ય કરવા માટે OK બટન દબાવો. જો કેટલાક "
"જવાબો ખોટા હોય, તો સંબંધિત લીટીઓ પર ક્રોસ આઇકોન દેખાશે. ભૂલો સુધારવા માટે, ખોટી "
"સંખ્યાઓને દૂર કરવા માટે તેના પર ક્લિક કરો અને અગાઉના પગલાંઓનું પુનરાવર્તન કરો."

#. Help manual
#: activities/tens_complement_find/ActivityInfo.qml:23
msgctxt "ActivityInfo|"
msgid ""
"Create pairs of numbers equal to ten. Select a number in the list, then "
"select an empty spot of an operation to move the selected number there."
msgstr ""
"દસ બરાબર સંખ્યાઓની જોડી બનાવો. સૂચિમાં એક સંખ્યા પસંદ કરો, પછી પસંદ કરેલી સંખ્યાને ત્યાં "
"ખસેડવા માટે ઓપરેશનની ખાલી જગ્યા પસંદ કરો."

#: activities/tens_complement_find/resource/1/Data.qml:56
msgctxt "Data|"
msgid "First number from 1 to 4."
msgstr "પ્રથમ સંખ્યા 1 થી 4 સુધી."

#: activities/tens_complement_find/resource/2/Data.qml:9
msgctxt "Data|"
msgid "First number from 5 to 9."
msgstr "પ્રથમ સંખ્યા 5 થી 9 સુધી."

#: activities/tens_complement_find/resource/4/Data.qml:9
msgctxt "Data|"
msgid "Find both numbers."
msgstr "બંને સંખ્યાઓ શોધો."

#. Activity title
#: activities/tens_complement_swap/ActivityInfo.qml:14
msgctxt "ActivityInfo|"
msgid "Swap ten's complement"
msgstr "દસના પૂરકની અદલાબદલી કરો"

#. Help title
#: activities/tens_complement_swap/ActivityInfo.qml:16
msgctxt "ActivityInfo|"
msgid "Swap the numbers to create pairs equal to ten."
msgstr "દસ બરાબર જોડી બનાવવા માટે સંખ્યાઓની અદલાબદલી કરો."

#. Help goal
#: activities/tens_complement_swap/ActivityInfo.qml:19
msgctxt "ActivityInfo|"
msgid ""
"Learn to use ten's complement to optimize the order of numbers in an "
"operation."
msgstr "ઓપરેશનમાં સંખ્યાઓના ક્રમને શ્રેષ્ઠ બનાવવા માટે દસના પૂરકનો ઉપયોગ કરવાનું શીખો."

#. Help prerequisite
#: activities/tens_complement_swap/ActivityInfo.qml:21
msgctxt "ActivityInfo|"
msgid "Numbers from 1 to 30 and addition."
msgstr "1 થી 30 સુધીની સંખ્યાઓ અને સરવાળો."

#. Help manual
#: activities/tens_complement_swap/ActivityInfo.qml:23
msgctxt "ActivityInfo|"
msgid ""
"Create pairs of numbers equal to ten within each parentheses. Select a "
"number, then select another number of the same operation to swap their "
"position. When all the lines are completed, press the OK button to validate "
"the answers. If some answers are incorrect, a cross icon will appear on the "
"corresponding lines. Correct the errors, then press the OK button again."
msgstr ""
"દરેક કૌંસમાં દસ બરાબર સંખ્યાઓની જોડી બનાવો. એક સંખ્યા પસંદ કરો, પછી તેમની સ્થિતિ બદલવા "
