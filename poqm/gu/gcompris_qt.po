#: activities/scalesboard_weight_avoirdupois/resource/6/Data.qml:86
#, qt-format
msgctxt "Data|"
msgid "Enter the weight of the gift in ounce: %1"
msgstr "ભેટનું વજન ઔંસમાં દાખલ કરો: %1"

#: activities/scalesboard_weight_avoirdupois/resource/2/Data.qml:13
msgctxt "Data|"
msgid "Balance up to 10 ounces."
msgstr "10 ઔંસ સુધી સંતુલિત કરો."

#: activities/scalesboard_weight_avoirdupois/resource/3/Data.qml:13
msgctxt "Data|"
msgid "Balance up to 20 ounces."
msgstr "20 ઔંસ સુધી સંતુલિત કરો."

#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:13
msgctxt "Data|"
msgid "Balance up to 10 pounds."
msgstr "10 પાઉન્ડ સુધી સંતુલિત કરો."

#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:16
#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:17
#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:18
#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:19
#: activities/scalesboard_weight_avoirdupois/resource/4/Data.qml:22
