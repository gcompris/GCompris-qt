#. Help manual
#: activities/adjacent_numbers/ActivityInfo.qml:22
msgctxt "ActivityInfo|"
msgid "Find the requested numbers and drag them to the corresponding spot."
msgstr "માંગેલા અંકો શોધો અને તેમને યોગ્ય જગ્યાએ ખેંચો."

#. One or more numbers to find, all at the beginning of the list. Don't display the %n in the translation if possible (actual English strings are "Find the previous number" and "Find the previous numbers")
#: activities/adjacent_numbers/Adjacent_numbers.qml:60
#, qt-format
msgctxt "Adjacent_numbers|"
msgid "Find the %n previous number(s)."
msgid_plural "Find the %n previous number(s)."
msgstr[0] "પહેલાની %n સંખ્યા(ઓ) શોધો."
msgstr[1] "પહેલાની %n સંખ્યા(ઓ) શોધો."

#. One or more numbers to find, at the end of the list. Don't display the %n in the translation if possible (actual English strings are "Find the next number" and "Find the next numbers")
#: activities/adjacent_numbers/Adjacent_numbers.qml:64
#, qt-format
msgctxt "Adjacent_numbers|"
msgid "Find the %n next number(s)."
msgid_plural "Find the %n next number(s)."
msgstr[0] "પછીની %n સંખ્યા(ઓ) શોધો."
msgstr[1] "પછીની %n સંખ્યા(ઓ) શોધો."

#. One or more numbers to find, not at the beginning nor at the end of the list. Don't display the %n in the translation if possible (actual English strings are "Find the in-between number" and "Find the in-between numbers")
#: activities/adjacent_numbers/Adjacent_numbers.qml:68
#, qt-format
msgctxt "Adjacent_numbers|"
msgid "Find the %n in-between number(s)"
msgid_plural "Find the %n in-between number(s)"
msgstr[0] "વચ્ચેની %n સંખ્યા(ઓ) શોધો."
msgstr[1] "વચ્ચેની %n સંખ્યા(ઓ) શોધો."

#. More than one number to find, with at least one number at the beginning or at the end of the list. Don't display the %n in the translation if possible (actual English string is "Find the missing numbers")
#: activities/adjacent_numbers/Adjacent_numbers.qml:72
#, qt-format
msgctxt "Adjacent_numbers|"
msgid "Find the %n missing numbers"
msgid_plural "Find the %n missing numbers"
msgstr[0] "ખૂટતી %n સંખ્યાઓ શોધો."
msgstr[1] "ખૂટતી %n સંખ્યાઓ શોધો."

#: activities/adjacent_numbers/resource/1/Data.qml:9
msgctxt "Data|"
msgid "Find numbers between 1 and 10."
msgstr "1 અને 10 ની વચ્ચેના અંકો શોધો."

#: activities/adjacent_numbers/resource/2/Data.qml:9
msgctxt "Data|"
msgid "Find numbers between 0 and 20."
msgstr "0 અને 20 ની વચ્ચેના અંકો શોધો."

#: activities/adjacent_numbers/resource/3/Data.qml:9
msgctxt "Data|"
msgid "Find numbers between 0 and 100."
msgstr "0 અને 100 ની વચ્ચેના અંકો શોધો."

#: activities/adjacent_numbers/resource/4/Data.qml:9
msgctxt "Data|"
msgid "Find numbers between -10 and -1."
msgstr "-10 અને -1 ની વચ્ચેના અંકો શોધો."

#: activities/adjacent_numbers/resource/5/Data.qml:9
msgctxt "Data|"
msgid "Find numbers between -10 and 10."
msgstr "-10 અને 10 ની વચ્ચેના અંકો શોધો."

