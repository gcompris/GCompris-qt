msgctxt "Data|"
msgid "Find numerator (with a square)."
msgstr "અંશ શોધો (ચોરસ સાથે)."

#: activities/fractions_find/resource/3/Data.qml:9
msgctxt "Data|"
msgid "Find denominator (with a pie)."
msgstr "છેદ શોધો (પાઈ સાથે)."

